{
  "day": {
    "prefix": "dd",
    "body": "$CURRENT_YEAR/$CURRENT_MONTH/$CURRENT_DATE",
    "description": "day"
  },
  "date": {
    "prefix": "date",
    "body": "$CURRENT_YEAR/$CURRENT_MONTH/$CURRENT_DATE $CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND",
    "description": "date"
  },
  "mark": {
    "prefix": "mark",
    "body": "$CURRENT_YEAR/$CURRENT_MONTH/$CURRENT_DATE: $1",
    "description": "mark"
  },
  "descriptor": {
    "prefix": "de",
    "body": "/* $0 */",
    "description": "descriptor"
  }
}
