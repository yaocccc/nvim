{
  "space": {
    "prefix": "sp",
    "body": "&nbsp;",
    "description": "space"
  },
  "undefined": {
    "prefix": "un",
    "body": "undefined"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if (${1:true}) {",
      "\t$0",
      "}"
    ],
    "description": "if (condition) { ... }"
  },
  "switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:expression}) {",
      "\tcase '${3:case}':",
      "\t\t$4",
      "\t\tbreak;",
      "\t$0",
      "\tdefault:",
      "\t\t$2",
      "}"
    ]
  },
  "case": {
    "prefix": "case",
    "body": [
      "case '${1:case}':",
      "\t$0",
      "\tbreak;"
    ],
    "description": "case 'xyz': ... break"
  },
  "try": {
    "prefix": "try",
    "body": [
      "try {",
      "\t$0",
      "} catch (${1:e}) {",
      "\t${2:/* handle error */}",
      "}"
    ],
    "description": "try { ... } catch(e) { ... }"
  },
  "return": {
    "prefix": "ret",
    "body": "return ${0:result};"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for (let ${1:i} = 0; ${1} < ${2:100}; ${1}++) {",
      "\t$0",
      "}"
    ],
    "description": "for loop"
  },
  "while": {
    "prefix": "wh",
    "body": [
      "while (${1:/* condition */}) {",
      "\t$0",
      "}"
    ],
    "description": "while (condition) { ... }"
  },
  "console.log": {
    "prefix": "cl",
    "body": "console.log($0);"
  },
  "console.time": {
    "prefix": "ct",
    "body": "console.time(\"$0\");"
  },
  "console.timeEnd": {
    "prefix": "cte",
    "body": "console.timeEnd(\"$0\");"
  },
  "const": {
    "prefix": "const",
    "body": "const ${1} = $0;"
  },
  "let": {
    "prefix": "let",
    "body": "let ${1} = $0;"
  },
  "import": {
    "prefix": "im",
    "body": "import ${2} from '${1}';",
    "description": "import xyz from 'xyz'"
  },
  "await": {
    "prefix": "aw",
    "body": "await $0"
  },
  "comment": {
    "prefix": "cm",
    "body": "<!-- $0 -->"
  },
  "constructor": {
    "prefix": "con",
    "body": [
      "constructor(${1}) {",
      "\t${2}",
      "}"
    ]
  },
  "function": {
    "prefix": "fun",
    "body": "function"
  }
}
